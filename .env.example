# MicroMail Environment Configuration

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# API Gateway
AUTH_SERVICE_URL=http://localhost:8001
COMPOSER_SERVICE_URL=http://localhost:8002
STORAGE_SERVICE_URL=http://localhost:8003
DELIVERY_SERVICE_URL=http://localhost:8004

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# Database URLs (for direct service connection)
AUTH_DB_URL=postgresql://auth_user:auth_password@localhost:5432/auth_db
COMPOSER_DB_URL=postgresql://composer_user:composer_password@localhost:5433/composer_db
STORAGE_DB_URL=postgresql://storage_user:storage_password@localhost:5434/storage_db

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# SMTP Configuration (for mail delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Redis (Optional, for caching)
REDIS_URL=redis://localhost:6379

# Feature Flags
ENABLE_REAL_TIME=true
ENABLE_WEBSOCKET=true
DEBUG_MODE=false



#TESTING BE on React tsx 
DATABASE_URL =postgresql://test_user:test_password@localhost:5435/test_db
JWT_SECRET_KEY = your-test-secret-key-change-in-production-min-32-chars